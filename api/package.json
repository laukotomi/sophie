{
    "name": "sophie-api",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/index.ts",
        "build": "tsc",
        "start": "node --env-file=.env dist/index.js",
        "db:push": "node --env-file=.env node_modules/.bin/drizzle-kit push",
        "create-user": "tsx --env-file=.env scripts/create-user.ts",
        "db:generate": "node --env-file=.env node_modules/.bin/drizzle-kit generate",
        "db:migrate": "node --env-file=.env node_modules/.bin/drizzle-kit migrate",
        "db:studio": "node --env-file=.env node_modules/.bin/drizzle-kit studio",
        "auth:schema": "better-auth generate --config src/auth.ts --output src/db/auth.schema.ts --yes"
    },
    "dependencies": {
        "@hono/node-server": "^1.14.4",
        "better-auth": "~1.4.21",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.7.10",
        "postgres": "^3.4.8"
    },
    "devDependencies": {
        "@better-auth/cli": "~1.4.21",
        "@types/node": "^24",
        "drizzle-kit": "^0.31.8",
        "tsx": "^4.19.4",
        "typescript": "^5.9.3"
    }
}