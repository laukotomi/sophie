# Database
DATABASE_URL=postgres://user:password@localhost:5432/sophie

# Server
PORT=3000
# Base URL of this API server (used by better-auth)
ORIGIN=http://localhost:3000
# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5173
# Directory where uploaded files are stored
UPLOADS_DIR=./uploads

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret
